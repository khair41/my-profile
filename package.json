{
  "name": "my-profile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "crawl": "PYTHONPATH=. python3 pipeline/run.py --crawl",
    "digest": "PYTHONPATH=. python3 pipeline/run.py --digest",
    "ingest": "npm run crawl && npm run digest",
    "generate": "PYTHONPATH=. python3 pipeline/run.py --generate all",
    "publish": "PYTHONPATH=. python3 pipeline/run.py --publish all",
    "seed": "PYTHONPATH=. python3 pipeline/run.py --generate all --passes 5 && PYTHONPATH=. python3 pipeline/run.py --publish all"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "js-yaml": "^4.1.1",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
